{
  "entities": {
    "ContactRequest": {
      "title": "Contact Request",
      "description": "A request from a potential client via the contact form.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the sender."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email of the sender."
        },
        "projectType": {
          "type": "string",
          "description": "The type of project requested."
        },
        "budget": {
          "type": "string",
          "description": "The estimated budget for the project."
        },
        "message": {
          "type": "string",
          "description": "The message content."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the request was created."
        }
      },
      "required": ["name", "email", "projectType", "budget", "message", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "A portfolio project.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "link": { "type": "string" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "image", "link", "order"]
    }
  },
  "firestore": {
    "contact_requests/{requestId}": {
      "schema": "ContactRequest",
      "description": "Collection of contact requests."
    },
    "projects/{projectId}": {
      "schema": "Project",
      "description": "Portfolio projects."
    },
    "dribbble_projects/{projectId}": {
      "schema": "Project",
      "description": "Dribbble projects."
    }
  }
}
